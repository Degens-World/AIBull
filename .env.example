WEBULL_APP_KEY=your_app_key_here
WEBULL_APP_SECRET=your_app_secret_here
WEBULL_TRADING_PIN=your_6digit_pin
WEBULL_ACCOUNT_ID=your_account_id

# Claude API for AI agent
ANTHROPIC_API_KEY=your_anthropic_key_here

# Set to "paper" or "live"
TRADING_MODE=paper

# Telegram bot (optional — for remote control and alerts)
# 1. Create a bot via @BotFather on Telegram → get the token
# 2. Start the bot, then send /start → your chat_id appears in the app Settings page
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# LLM backend: claude_cli | ollama | anthropic  (default: claude_cli)
LLM_BACKEND=claude_cli
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# App settings
PORT=8421
